# Скопируй в .env и подставь значения из Supabase → Project Settings → API

# Публичные (можно использовать на фронте):
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Секретный service_role ключ — ТОЛЬКО для scripts/generate.js (заливка пазлов).
# Никогда не клади его во фронт и не коммить!
SUPABASE_SERVICE_KEY=eyJhbGciOi...
